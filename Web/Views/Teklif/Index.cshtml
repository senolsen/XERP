@model IEnumerable<Core.Entities.Teklif>
@{
    ViewData["Title"] = "Teklifler";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="text-primary"><i class="fa fa-list me-2"></i>Teklif Listesi</h3>

        <div>
            <a href="/ReportDesigner/Index?id=Yeni_Tasarim" class="btn btn-warning text-dark me-2 shadow-sm">
                <i class="fa fa-paint-brush me-1"></i> Şablon Tasarla
            </a>

            <a href="/Teklif/Create" class="btn btn-success shadow-sm">
                <i class="fa fa-plus me-1"></i> Yeni Teklif Oluştur
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive" style="overflow: visible; min-height: 350px;">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Teklif No</th>
                            <th>Müşteri (Cari)</th>
                            <th>Tarih</th>
                            <th>Toplam Tutar</th>
                            <th class="text-end pe-4">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">Henüz hiç teklif oluşturulmamış.</td>
                            </tr>
                        }
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold">@item.TeklifNo</td>
                                <td>@item.Musteri?.Unvan</td>
                                <td>@item.Tarih.ToString("dd.MM.yyyy HH:mm")</td>
                                <td><span class="badge bg-success fs-6">@item.ToplamTutar.ToString("N2") ₺</span></td>
                                <td class="text-end pe-4">
                                    <div class="btn-group">

                                        <div class="btn-group" role="group">
                                            <button type="button" class="btn btn-sm btn-outline-primary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                                                <i class="fa fa-print"></i> Yazdır
                                            </button>
                                            <ul class="dropdown-menu shadow-sm border-0">
                                                @if (ViewBag.Templates != null && ((IEnumerable<Core.Entities.ReportTemplate>)ViewBag.Templates).Any())
                                                {
                                                    <li class="dropdown-header text-muted">Şablon Seçin</li>
                                                    foreach (var tpl in (IEnumerable<Core.Entities.ReportTemplate>)ViewBag.Templates)
                                                    {
                                                        <li>
                                                            <a class="dropdown-item py-2" href="/DocumentViewer/TeklifYazdir?id=@item.Id&templateId=@tpl.Id" target="_blank">
                                                                <i class="fa fa-file-pdf text-danger me-2"></i> @tpl.Name
                                                            </a>
                                                        </li>
                                                    }
                                                }
                                                else
                                                {
                                                    <li><span class="dropdown-item text-muted">Şablon Bulunamadı</span></li>
                                                }
                                            </ul>
                                        </div>

                                        <button class="btn btn-sm btn-outline-info"><i class="fa fa-eye"></i> İncele</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>